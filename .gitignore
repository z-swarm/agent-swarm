## .gitignore for agent-swarm

# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
.venv/
.venv-win/
venv/
.python-version

# 构建产物
build/
dist/
*.whl

# 测试 & 覆盖
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# 类型检查
.mypy_cache/
.ruff_cache/

# 不上传的设计文档 (W43+ 部分入 git: DESIGN.md + docs/MEMORY/PHASE*-PLAN/PHASE*-RETRO/P5-RETRO; 临时复盘仍本地)
DESIGN.md
docs/
!docs/MEMORY.md
!docs/PHASE*-PLAN*.md
!docs/PHASE*-RETRO.md
!docs/P5-RETRO.md

# IDE
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json

# 运行时产物
*.log
*.db
*.db-shm
*.db-wal
sessions.db
.env
.env.local

# LLM 录制（不进 git；仅 _recordings_baseline 进）
tests/_recordings_local/

# 演示录屏（大文件不进主仓库；用 git-lfs 或外部存储）
demos/*.mp4

# W 阶段计划文档 (本地保留, 不入 git; W40 起所有 W 阶段 PLAN 都不上传)
W*_PLAN.md
W*_RETRO_PLAN.md
W*_RETRO.md
